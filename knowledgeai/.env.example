# Copy this file to .env and fill in your values
OPENAI_API_KEY=sk-...

# Optional: path to your BRDs folder (defaults to ./BRDs)
BRD_FOLDER=./BRDs

# Server settings
HOST=0.0.0.0
PORT=8000

# LLM settings
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# Chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=50

# Retrieval
TOP_K=10
RERANK_TOP_N=3
CONFIDENCE_THRESHOLD=0.20

# Cache
CACHE_MAX_SIZE=500
CACHE_SIMILARITY_THRESHOLD=0.92
